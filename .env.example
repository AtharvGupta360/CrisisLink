# Copy to `.env` for docker compose to pick up. `.env` is gitignored (secrets
# never touch the repo); this `.example` documents the shape. The compose file
# also has built-in defaults, so the stack runs even without a .env in dev.
POSTGRES_USER=crisislink
POSTGRES_PASSWORD=crisislink_dev_pw
POSTGRES_DB=crisislink

# App runtime: "production" puts Gin in release mode. Anything else = development.
APP_ENV=development

GRAFANA_ADMIN_PASSWORD=admin

# The app (P3+) reads this to reach Postgres from the HOST. Note host port 5433
# (compose maps 5433->5432) to avoid a native PostgreSQL already on 5432, and
# 127.0.0.1 (not "localhost") to force IPv4 and dodge IPv6/::1 ambiguity.
DATABASE_URL=postgres://crisislink:crisislink_dev_pw@127.0.0.1:5433/crisislink?sslmode=disable
