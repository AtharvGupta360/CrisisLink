# Copy to `.env` for docker compose to pick up. `.env` is gitignored (secrets
# never touch the repo); this `.example` documents the shape. The compose file
# also has built-in defaults, so the stack runs even without a .env in dev.
POSTGRES_USER=crisislink
POSTGRES_PASSWORD=crisislink_dev_pw
POSTGRES_DB=crisislink

GRAFANA_ADMIN_PASSWORD=admin

# The app (P3+) will read this to reach Postgres from the HOST:
DATABASE_URL=postgres://crisislink:crisislink_dev_pw@localhost:5432/crisislink?sslmode=disable
